            "body": { "mode": "raw", "raw": "{\n  \"email\": \"zainab@test.com\",\n  \"password\": \"Password123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Login — Wrong Password (401)",
