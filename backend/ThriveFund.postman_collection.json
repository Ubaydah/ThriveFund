    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.test('Returns user + tokens', () => {",
            "  const b = pm.response.json();",
            "  pm.expect(b.success).to.be.true;",
            "  pm.expect(b.data).to.have.all.keys('user','tokens');",
            "  pm.expect(b.data.tokens).to.have.property('access_token');",
            "});",
            "if (pm.response.code === 201) {",
            "  const b = pm.response.json();",
            "  pm.collectionVariables.set('access_token',  b.data.tokens.access_token);",
            "  pm.collectionVariables.set('refresh_token', b.data.tokens.refresh_token);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Zainab Fadeyi\",\n  \"email\": \"zainab@test.com\",\n  \"password\": \"Password123\",\n  \"phone_number\": \"08012345678\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Register — Duplicate Email (409)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('409 for duplicate email', () => pm.response.to.have.status(409));",
            "pm.test('Error code CONFLICT', () => pm.expect(pm.response.json().error.code).to.eql('CONFLICT'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Zainab Fadeyi\",\n  \"email\": \"zainab@test.com\",\n  \"password\": \"Password123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        },
        {
