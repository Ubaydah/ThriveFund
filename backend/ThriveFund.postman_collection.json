          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK (always, no enumeration)', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"zainab@test.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth","forgot-password"] }
          }
        },
        {
          "name": "Logout",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
